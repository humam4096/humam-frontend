roperty\":\"og:title\",\"content\":\"Humam Consulting | Expert Quality Assurance\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:description\",\"content\":\"Premium expertise in food safety, quality assurance, facility design, and specialized training.\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:url\",\"content\":\"https://humamconsulting.com\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:site_name\",\"content\":\"Humam Consulting\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"9\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"10\",{\"name\":\"twitter:title\",\"content\":\"Humam Consulting\"}],[\"$\",\"meta\",\"11\",{\"name\":\"twitter:description\",\"content\":\"Expert consultancy and quality assurance for the food industry.\"}],[\"$\",\"link\",\"12\",{\"rel\":\"shortcut icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"link\",\"13\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.0b3bf435.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"14\",{\"rel\":\"icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"link\",\"15\",{\"rel\":\"apple-touch-icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"$L29\",\"16\",{}]]\n","/$d$locale/services/training/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[1341,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\",\"/_next/static/chunks/693096fed6d5e765.js\",\"/_next/static/chunks/3815780282fa1bc8.js\"],\"default\"]\n3:I[20932,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\",\"/_next/static/chunks/693096fed6d5e765.js\",\"/_next/static/chunks/3815780282fa1bc8.js\"],\"default\"]\n4:I[97367,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"OutletBoundary\"]\n5:\"$Sreact.suspense\"\n:HL[\"/_next/static/chunks/e35a295a84ef66ff.css\",\"style\"]\n:HL[\"/_next/static/chunks/cc6a39f6c6655594.css\",\"style\"]\n0:{\"buildId\":\"0i1CMrDrpYBb3UiQbLup2\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"main\",null,{\"children\":[[\"$\",\"$L2\",null,{\"eyebrow\":\"التدريب والتطوير\",\"title\":\"حوّل الفرق. ارتقِ بالأداء.\",\"subtitle\":\"برامج متخصصة تبني القدرات وتغرس التميز وتحقق تأثيراً تشغيلياً دائماً على كل مستوى في مؤسستك.\",\"gradient\":\"mustard\"}],[\"$\",\"div\",null,{\"className\":\"PatternDivider-module__ZW-8xG__divider \",\"style\":{\"backgroundImage\":\"url(/patterns/pattern-zigzag-strip.png)\"},\"aria-hidden\":\"true\"}],[\"$\",\"$L3\",null,{\"eyebrow\":\"فلسفة التدريب\",\"heading\":\"معرفة تنتقل. مهارات تبقى.\",\"description\":\"برامجنا التدريبية مصممة من قبل ممارسين وليس منظّرين. كل جلسة تجمع بين التطبيق العملي والتجربة الواقعية — لأن التغيير الدائم يحدث بالممارسة لا بالتعلم فقط.\"}]]}],[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/e35a295a84ef66ff.css\",\"precedence\":\"next\"}],[\"$\",\"link\",\"1\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/cc6a39f6c6655594.css\",\"precedence\":\"next\"}],[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/693096fed6d5e765.js\",\"async\":true}],[\"$\",\"script\",\"script-1\",{\"src\":\"/_next/static/chunks/3815780282fa1bc8.js\",\"async\":true}]],[\"$\",\"$L4\",null,{\"children\":[\"$\",\"$5\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@6\"}]}]]}],\"loading\":null,\"isPartial\":false}\n6:null\n","/$d$locale/services/training":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"default\"]\n0:{\"buildId\":\"0i1CMrDrpYBb3UiQbLup2\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"loading\":null,\"isPartial\":false}\n","/$d$locale/services":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"default\"]\n3:I[37457,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"default\"]\n0:{\"buildId\":\"0i1CMrDrpYBb3UiQbLup2\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"loading\":null,\"isPartial\":false}\n","/$d$locale":"1:\"$Sreact.fragment\"\n2:I[75696,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\"],\"default\"]\n6:I[7988,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\"],\"default\"]\n7:I[39756,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"default\"]\n8:I[37457,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"default\"]\n9:I[61259,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\",\"/_next/static/chunks/54f16660fae19f85.js\",\"/_next/static/chunks/3815780282fa1bc8.js\"],\"default\"]\na:I[77105,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\",\"/_next/static/chunks/693096fed6d5e765.js\",\"/_next/static/chunks/3815780282fa1bc8.js\"],\"default\"]\nb:I[85437,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\"],\"Image\"]\nc:I[87564,[\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"/_next/static/chunks/b15dc6fd94cfc275.js\"],\"default\"]\n:HL[\"/_next/static/chunks/60e2688c675c4b40.css\",\"style\"]\n:HL[\"/_next/static/chunks/cc6a39f6c6655594.css\",\"style\"]\n0:{\"buildId\":\"0i1CMrDrpYBb3UiQbLup2\",\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/60e2688c675c4b40.css\",\"precedence\":\"next\"}],[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/51ddee8f1e24f7fa.js\",\"async\":true}],[\"$\",\"script\",\"script-1\",{\"src\":\"/_next/static/chunks/b15dc6fd94cfc275.js\",\"async\":true}]],[\"$\",\"html\",null,{\"lang\":\"ar\",\"dir\":\"rtl\",\"className\":\"inter_c15e96cb-module__0bjUvq__variable outfit_9f4f9187-module__4LtYgq__variable tajawal_7b9e7912-module__S44iHW__variable\",\"children\":[\"$\",\"body\",null,{\"children\":[\"$\",\"$L2\",null,{\"locale\":\"ar\",\"messages\":{\"HomePage\":{\"badge\":\"مدعومون بالتميز\",\"title\":\"ارتقِ بجودة الغذاء\",\"subtitle\":\"نضمن لك نجاحاً مستداماً.\",\"description\":\"استشارات الخبراء، التخطيط الهيكلي، وضمان الجودة لصناعة تقديم الطعام الحديثة والأغذية.\",\"ctaPrimary\":\"ناقش مشروعك\",\"ctaSecondary\":\"اكتشف خدماتنا\"},\"Navbar\":{\"home\":\"الرئيسية\",\"about\":\"من نحن\",\"services\":\"خدماتنا\",\"industries\":\"القطاعات\",\"training\":\"مركز التدريب\",\"contact\":\"تواصل معنا\",\"login\":\"بوابة العملاء\"},\"About\":{\"eyebrow\":\"قصتنا\",\"title\":\"منارة في بحر الغذاء.\",\"description\":\"يتخصص همام في توجيه الأعمال في قطاع الأغذية، بدءًا من الإنتاج والطبخ إلى التصنيع والتدريب وخدمات الجودة وتخطيط الدعم اللوجستي.\",\"cta\":\"اعرف المزيد عن همام\",\"pillars\":{\"dev\":\"تطوير الأعمال\",\"safety\":\"سلامة وجودة الغذاء\",\"training\":\"التدريب ورأس المال البشري\"}},\"Services\":{\"eyebrow\":\"خبراتنا\",\"title\":\"حلول شاملة لقطاع الأغذية\",\"dev\":{\"title\":\"الاستشارات وتطوير الأعمال\",\"desc\":\"التخطيط الاستراتيجي، تصميم القوائم، والتميز التشغيلي لمشاريع الأغذية.\"},\"safety\":{\"title\":\"الجودة وسلامة الغذاء\",\"desc\":\"إعداد شهادات الآيزو والهاسب وعمليات تدقيق السلامة الصارمة.\"},\"training\":{\"title\":\"التدريب والتطوير\",\"desc\":\"تمكين الطهاة والموظفين عبر برامج متخصصة في الطهي والسلامة.\"}},\"Industries\":{\"eyebrow\":\"نطاق عملنا\",\"title\":\"القطاعات التي نخدمها\",\"list\":{\"rest\":\"المطاعم وخدمات الإعاشة\",\"bakery\":\"المخابز والحلويات\",\"factory\":\"مصانع الأغذية\",\"hotel\":\"الفنادق والمقاهي\",\"hajj\":\"شركات الحج والعمرة\",\"healthy\":\"شركات الوجبات الصحية\"}},\"Challenges\":{\"eyebrow\":\"تحديات نتغلب عليها\",\"title\":\"لماذا تختار همام\",\"description\":\"نساعدك في التغلب على تعقيدات قطاع الأغذية وتحويل العقبات إلى نمو مستدام.\",\"list\":{\"quality\":{\"title\":\"الموازنة بين الجودة والتكلفة\",\"desc\":\"تقديم جودة عالية بأسعار معقولة دون المساس بالمعايير.\"},\"efficiency\":{\"title\":\"تحسين الكفاءة التشغيلية\",\"desc\":\"تبسيط العمليات الداخلية لتقليل التكاليف وزيادة الإنتاجية.\"},\"growth\":{\"title\":\"إطلاق مشاريع جديدة\",\"desc\":\"توجيه النمو والتوسع من الفكرة الأولية إلى التنفيذ السلس.\"},\"sustainability\":{\"title\":\"تحقيق الاستدامة\",\"desc\":\"الموازنة بين الربحية والمسؤولية الاجتماعية والبيئية.\"},\"reputation\":{\"title\":\"بناء سمعة قوية\",\"desc\":\"تأسيس علامة تجارية موثوقة تجذب العملاء والشركاء.\"}}},\"Experts\":{\"eyebrow\":\"قيادتنا\",\"title\":\"تعرف على الخبراء\",\"list\":{\"atef\":{\"name\":\"عاطف العريشي\",\"role\":\"المدير العام\",\"bio\":\"27 عاماً في إدارة الإعاشة للحجاج والمعتمرين، مع خبرة في سلسلة التوريد والوجبات مسبقة التحضير.\"},\"enas\":{\"name\":\"إيناس خضري\",\"role\":\"شيف استشاري\",\"bio\":\"16 عاماً من الخبرة في الطهي، ومعتمدة من هيئة فنون الطهي كخبيرة في المطبخ السعودي.\"},\"alaa\":{\"name\":\"آلاء زهدي\",\"role\":\"مهندسة تصنيع أغذية\",\"bio\":\"متخصصة في عمليات تصنيع الأغذية، ضمان الجودة، واعتماد الابتكارات التكنولوجية.\"}}},\"FinalCTA\":{\"title\":\"هل أنت مستعد للارتقاء بأعمالك الغذائية؟\",\"cta\":\"ابدأ رحلتك\"},\"ServicesPage\":{\"hero\":{\"eyebrow\":\"خدماتنا\",\"title\":\"حلول مبنية بدقة لقطاع الأغذية\",\"subtitle\":\"من الاستراتيجية إلى الشهادات، ومن التدريب إلى التحول — نقدم خبرة شاملة ترتقي بكل مستوى من عملياتك الغذائية.\"},\"philosophy\":{\"eyebrow\":\"منهجيتنا\",\"heading\":\"أنظمة تتوسع. معايير تدوم.\",\"p1\":\"كل مشروع يبدأ بفهم عميق. ندرس عملياتك وسوقك وأهدافك قبل أن نوصي بأي تغيير.\",\"p2\":\"منهجيتنا تدمج الاستشارات وأنظمة الجودة وتطوير الكوادر البشرية في إطار موحد — لأن النجاح المستدام يتطلب الثلاثة معاً.\",\"p3\":\"لا نقدم قوالب جاهزة. نبني أنظمة مصممة خصيصاً لسياقك وثقافتك ومسار نموك.\"},\"consultancy\":{\"number\":\"01\",\"eyebrow\":\"الاستشارات وتطوير الأعمال\",\"title\":\"ابنِ الأساس. صمّم المستقبل.\",\"description\":\"التخطيط الاستراتيجي والهندسة التشغيلية وتصميم القوائم للمنشآت الغذائية التي تطلب التميز.\",\"body\":\"نعمل جنباً إلى جنب مع المؤسسين والمشغلين وفرق القيادة لتصميم كل طبقة من أعمالك الغذائية — من المفهوم الأولي حتى التوسع المستدام. استشاراتنا ليست نظرية، بل مبنية على عقود من الخبرة العملية في قطاع الأغذية.\",\"cta\":\"اكتشف الاستشارات\",\"benefits\":\"استشارات مكتبية وميدانية, تصميم وهندسة القوائم, إنشاء المشاريع والتخطيط, الأنظمة التشغيلية وإجراءات العمل, حسابات التكاليف والسعرات الحرارية, التحول نحو الاستدامة\",\"items\":{\"office\":{\"title\":\"الاستشارات المكتبية والميدانية\",\"desc\":\"تقييمات خبراء في الموقع وعن بعد لتشخيص عملياتك والارتقاء بها.\"},\"menu\":{\"title\":\"تصميم وهندسة القوائم\",\"desc\":\"تطوير قوائم مبني على البيانات يوازن بين الإبداع والتكلفة وطلب العملاء.\"},\"project\":{\"title\":\"إنشاء المشاريع والتخطيط\",\"desc\":\"إعداد شامل للمشاريع الغذائية الجديدة — من الفكرة إلى الإطلاق التشغيلي.\"}}},\"quality\":{\"number\":\"02\",\"eyebrow\":\"الجودة وسلامة الغذاء\",\"title\":\"اعتمد. احمِ. تفوّق.\",\"description\":\"أنظمة جودة دولية وبروتوكولات سلامة غذائية وأطر امتثال تحمي علامتك التجارية وعملاءك.\",\"body\":\"من شهادات الآيزو إلى تطبيق الهاسب، نبني البنية التحتية للجودة التي يثق بها المراقبون ويعتمد عليها العملاء. كل نظام نصممه جاهز للتدقيق من اليوم الأول — مع التوثيق الكامل وتدريب الموظفين وأطر التحسين المستمر.\",\"cta\":\"اكتشف أنظمة الجودة\",\"benefits\":\"شهادات ISO 9001 و ISO 22000, تطبيق نظام HACCP, ممارسات التصنيع الجيدة (GMP), أطر التدقيق الداخلي, توثيق الامتثال, بروتوكولات الإجراءات التصحيحية\",\"items\":{\"iso\":{\"title\":\"أنظمة شهادات الآيزو\",\"desc\":\"تطبيق ISO 9001 و ISO 22000 مع التوثيق الكامل والجاهزية للتدقيق.\"},\"haccp\":{\"title\":\"HACCP و GMP\",\"desc\":\"تحليل المخاطر ونقاط التحكم الحرجة وممارسات التصنيع الجيدة لكل خط إنتاج.\"},\"audit\":{\"title\":\"التدقيق والامتثال\",\"desc\":\"عمليات تدقيق سلامة شاملة مع إجراءات تصحيحية قابلة للتنفيذ ومراقبة مستمرة.\"}}},\"training\":{\"number\":\"03\",\"eyebrow\":\"التدريب والتطوير\",\"title\":\"استثمر في الكوادر. ضاعف النتائج.\",\"description\":\"برامج تدريب متخصصة في الطهي والتشغيل تحول الفرق إلى أصول عالية الأداء.\",\"body\":\"برامجنا التدريبية مصممة من قبل ممارسين قادوا المطابخ وأداروا العمليات وبنوا الفرق من الصفر. كل جلسة تجمع بين التطبيق العملي والتجربة الواقعية — لأن التغيير الدائم يحدث بالممارسة.\",\"cta\":\"اكتشف برامج التدريب\",\"benefits\":\"برامج تدريب الموظفين, تطوير الطهاة والتقنيات, ورش عمل متخصصة, إعداد شهادات سلامة الغذاء, تدريب القيادة المطبخية, تصميم برامج مخصصة\",\"items\":{\"employee\":{\"title\":\"تدريب الموظفين\",\"desc\":\"برامج تأسيسية ومتقدمة لفرق المطبخ والخدمة ومديري العمليات.\"},\"chef\":{\"title\":\"تطوير الطهاة\",\"desc\":\"تقنيات طهي متقدمة وابتكار القوائم وتطوير القيادة للطهاة المحترفين.\"},\"specialized\":{\"title\":\"ورش العمل والبرامج المتخصصة\",\"desc\":\"جلسات مركزة في سلامة الغذاء والاستدامة وأفضل الممارسات القطاعية.\"}}}},\"ConsultancyPage\":{\"hero\":{\"eyebrow\":\"الاستشارات وتطوير الأعمال\",\"title\":\"هندسة استراتيجية للتميز الغذائي\",\"subtitle\":\"من المفهوم الأولي إلى الإتقان التشغيلي — نصمم الأطر التي تحول الطموح إلى أعمال غذائية مستدامة وقابلة للتوسع.\"},\"intro\":{\"eyebrow\":\"ما نقدمه\",\"heading\":\"كل تفصيل. مهندس للنمو.\",\"description\":\"تغطي استشاراتنا الطيف الكامل لتطوير الأعمال الغذائية — سواء كنت تطلق مفهوماً جديداً أو تحسن عملية قائمة أو تتوسع عبر مواقع متعددة.\"},\"offerings\":{\"office\":{\"title\":\"الاستشارات المكتبية\",\"desc\":\"جلسات استراتيجية معمقة في مكاتبنا لتحليل نموذج عملك وتحديد الفجوات ورسم مسار نموك.\",\"included\":\"تحليل نموذج العمل، تقييم الفجوات، خارطة طريق استراتيجية، قياس الأداء\"},\"field\":{\"title\":\"الاستشارات الميدانية\",\"desc\":\"تقييمات خبراء في الموقع لمرافقك وسير عملك وأداء فريقك مع خطط تحسين قابلة للتنفيذ.\",\"included\":\"تدقيق المرافق، تحليل سير العمل، تقييم الموظفين، خطة إجراءات تصحيحية\"},\"menu\":{\"title\":\"تصميم القوائم\",\"desc\":\"هندسة قوائم مبنية على البيانات توازن بين الإبداع في الطهي وتحسين التكاليف والتموضع السوقي.\",\"included\":\"هندسة القوائم، استراتيجية التسعير، توريد المكونات، التخطيط الموسمي\"},\"project\":{\"title\":\"إنشاء المشاريع\",\"desc\":\"توجيه شامل لإعداد المشاريع الغذائية الجديدة — من تطوير المفهوم حتى الإطلاق التشغيلي.\",\"included\":\"تصميم المفهوم، دراسة الجدوى، إرشاد التراخيص، تخطيط الإطلاق\"},\"operational\":{\"title\":\"التخطيط التشغيلي\",\"desc\":\"تحسين منهجي للعمليات اليومية لزيادة الكفاءة وتقليل الهدر وتحسين الاتساق.\",\"included\":\"تطوير إجراءات التشغيل، تصميم سير العمل، تخطيط الطاقة، أطر مؤشرات الأداء\"},\"sustainability\":{\"title\":\"التحول نحو الاستدامة\",\"desc\":\"انتقل بعملياتك نحو ممارسات مستدامة دون المساس بالجودة أو الربحية.\",\"included\":\"تقليل الهدر، تحسين الطاقة، التوريد المستدام، أطر التقارير\"},\"cost\":{\"title\":\"حسابات التكاليف\",\"desc\":\"تحليل ونمذجة دقيقة للتكاليف لحماية الهوامش وتحسين المشتريات وضمان الاستدامة المالية.\",\"included\":\"تحليل تكلفة الغذاء، نمذجة تكلفة العمالة، توزيع المصاريف العامة، تحسين التسعير\"},\"calorie\":{\"title\":\"حسابات السعرات الحرارية\",\"desc\":\"تحليل غذائي دقيق وحسابات السعرات الحرارية للامتثال وتوجيه القوائم الصحية.\",\"included\":\"التحليل الغذائي، خرائط مسببات الحساسية، امتثال التوسيم، تطوير قوائم صحية\"}}},\"QualityPage\":{\"hero\":{\"eyebrow\":\"الجودة وسلامة الغذاء\",\"title\":\"معايير دولية. تنفيذ لا يقبل التنازل.\",\"subtitle\":\"نبني أنظمة إدارة الجودة التي تحمي علامتك التجارية وترضي الجهات الرقابية وتمنح عملاءك ثقة مطلقة.\"},\"intro\":{\"eyebrow\":\"إطار الجودة\",\"heading\":\"أنظمة مبنية للاعتماد. مصممة لتدوم.\",\"description\":\"من شهادات الآيزو إلى تطبيق الهاسب، نقدم تصميماً شاملاً لأنظمة الجودة والتوثيق والتدريب والإعداد للتدقيق.\"},\"standards\":{\"iso9001\":{\"title\":\"ISO 9001\",\"subtitle\":\"نظام إدارة الجودة\",\"goal\":\"إنشاء نظام شامل لإدارة الجودة يضمن جودة المنتج المستمرة والتحسين المستمر.\",\"included\":\"تطوير سياسة الجودة، توثيق العمليات، إطار التدقيق الداخلي، نظام مراجعة الإدارة، إجراءات الإجراءات التصحيحية\",\"steps\":\"تحليل الفجوات، تصميم النظام، التوثيق، تدريب الموظفين، التدقيق الداخلي، تدقيق الشهادة\"},\"iso22000\":{\"title\":\"ISO 22000\",\"subtitle\":\"نظام إدارة سلامة الغذاء\",\"goal\":\"تطبيق نظام معترف به دولياً لإدارة سلامة الغذاء يغطي سلسلة الغذاء بأكملها.\",\"included\":\"تحليل المخاطر، البرامج الشرطية المسبقة، توثيق النظام، أنظمة التتبع، الاستعداد للطوارئ\",\"steps\":\"تقييم الوضع الحالي، تحديد المخاطر، تدابير التحكم، توثيق النظام، التحقق، الشهادة\"},\"haccp\":{\"title\":\"HACCP\",\"subtitle\":\"تحليل المخاطر ونقاط التحكم الحرجة\",\"goal\":\"تحديد وتقييم والتحكم في المخاطر ذات الأهمية لسلامة الغذاء في كل مرحلة من مراحل الإنتاج.\",\"included\":\"تحليل المخاطر، تحديد نقاط التحكم الحرجة، الحدود الحرجة، إجراءات المراقبة، الإجراءات التصحيحية، بروتوكولات التحقق\",\"steps\":\"تشكيل الفريق، وصف المنتج، مخطط التدفق، تحليل المخاطر، تحديد نقاط التحكم الحرجة، التحقق من النظام\"},\"gmp\":{\"title\":\"GMP\",\"subtitle\":\"ممارسات التصنيع الجيدة\",\"goal\":\"ضمان أن المنتجات الغذائية يتم إنتاجها والتحكم فيها بشكل مستمر وفقاً لمعايير الجودة المناسبة لاستخدامها المقصود.\",\"included\":\"مراجعة تصميم المرافق، بروتوكولات النظافة، برامج مكافحة الآفات، صيانة المعدات، ممارسات العاملين\",\"steps\":\"تقييم المرافق، تطوير البروتوكولات، تدريب الموظفين، التطبيق، المراقبة، التحسين المستمر\"}}},\"TrainingPage\":{\"hero\":{\"eyebrow\":\"التدريب والتطوير\",\"title\":\"حوّل الفرق. ارتقِ بالأداء.\",\"subtitle\":\"برامج متخصصة تبني القدرات وتغرس التميز وتحقق تأثيراً تشغيلياً دائماً على كل مستوى في مؤسستك.\"},\"intro\":{\"eyebrow\":\"فلسفة التدريب\",\"heading\":\"معرفة تنتقل. مهارات تبقى.\",\"description\":\"برامجنا التدريبية مصممة من قبل ممارسين وليس منظّرين. كل جلسة تجمع بين التطبيق العملي والتجربة الواقعية — لأن التغيير الدائم يحدث بالممارسة لا بالتعلم فقط.\"},\"programs\":{\"employee\":{\"title\":\"تدريب الموظفين\",\"desc\":\"برامج تأسيسية شاملة لفرق المطبخ والخدمة ومديري العمليات. نبني الكفاءة الأساسية التي تتطلبها العمليات المتميزة.\",\"outcomes\":\"تحسين التعامل مع الغذاء، توحيد الإجراءات، تقليل الهدر، رفع ثقة الفريق\"},\"chef\":{\"title\":\"تطوير الطهاة\",\"desc\":\"برامج طهي متقدمة تركز على صقل التقنيات وابتكار القوائم والقيادة المطبخية والتطوير الإبداعي للطهاة المحترفين.\",\"outcomes\":\"تقنيات محسنة، قدرة على ابتكار القوائم، مهارات قيادية، ثقة إبداعية\"},\"workshops\":{\"title\":\"ورش العمل\",\"desc\":\"ورش عمل مكثفة ومركزة على مواضيع محددة — من الامتثال لسلامة الغذاء إلى ممارسات الاستدامة وتحليل اتجاهات القطاع.\",\"outcomes\":\"اكتساب مهارات مستهدف، جاهزية للشهادات، خطط تنفيذ عملية\"},\"specialized\":{\"title\":\"البرامج المتخصصة\",\"desc\":\"برامج تدريبية مصممة خصيصاً لتحدياتك التشغيلية المحددة وتركيبة فريقك وأهداف عملك.\",\"outcomes\":\"تطوير مهارات مخصص، مواءمة تشغيلية، تحسين أداء قابل للقياس\"}},\"cta\":{\"eyebrow\":\"مستعد للاستثمار في فريقك؟\",\"title\":\"اطلب برنامجاً تدريبياً\",\"description\":\"أخبرنا عن فريقك وأهدافك. سنصمم برنامجاً يحقق نتائج قابلة للقياس.\",\"button\":\"اطلب تدريباً\"}},\"ContactPage\":{\"title\":\"احجز استشارة\",\"description\":\"أحضر تحدياتك أو أهدافك أو عملياتك الحالية. سنقيّمها معك مباشرة — ونوضح لك كيف يمكن لهمام المساعدة.\",\"bullets\":{\"b1\":\"عملياتك. رؤية خبراء\",\"b2\":\"فجوات حقيقية محددة، حلول حقيقية مقترحة\",\"b3\":\"شاهد كيف يبدو التميز المنظم\"},\"testimonial\":{\"quote\":\"همام لم يقدموا استشارات فحسب — بل غيّروا طريقة تفكيرنا في الجودة والعمليات. النتائج تتحدث عن نفسها.\",\"role\":\"مدير العمليات\",\"company\":\"شركة إعاشة رائدة\"},\"info\":{\"emailLabel\":\"راسلنا\",\"email\":\"info@humam.sa\",\"locationLabel\":\"الموقع\",\"location\":\"جدة، المملكة العربية السعودية\"},\"form\":{\"heading\":\"تحدث مع همام\",\"name\":\"الاسم\",\"namePlaceholder\":\"اسمك\",\"email\":\"البريد الإلكتروني\",\"emailPlaceholder\":\"البريد المهني\",\"company\":\"الشركة (اختياري)\",\"companyPlaceholder\":\"الشركة\",\"message\":\"الرسالة\",\"messagePlaceholder\":\"أخبرنا عن عملياتك\",\"industry\":\"القطاع\",\"industryOptions\":{\"select\":\"اختر\",\"restaurants\":\"المطاعم وخدمات الإعاشة\",\"bakeries\":\"المخابز والحلويات\",\"factories\":\"مصانع الأغذية\",\"hotels\":\"الفنادق والمقاهي\",\"hajj\":\"شركات الحج والعمرة\",\"healthy\":\"شركات الوجبات الصحية\"},\"service\":\"الخدمة المطلوبة\",\"serviceOptions\":{\"select\":\"اختر\",\"consultancy\":\"الاستشارات وتطوير الأعمال\",\"quality\":\"الجودة وسلامة الغذاء\",\"training\":\"التدريب والتطوير\"},\"submit\":\"طلب استشارة\",\"submitting\":\"يرجى الانتظار...\",\"successTitle\":\"شكراً لاهتمامك!\",\"successMessage\":\"سنرد عليك خلال 24 ساعة.\",\"errorMessage\":\"حدث خطأ أثناء إرسال النموذج.\",\"required\":\"هذا الحقل مطلوب\",\"invalidEmail\":\"يرجى إدخال بريد إلكتروني صحيح\",\"responseTime\":\"نرد خلال 24 ساعة\",\"secure\":\"معلوماتك محفوظة بسرية تامة\"}},\"AboutPage\":{\"hero\":{\"eyebrow\":\"عن همام\",\"title\":\"منارة في بحر الغذاء، من الأرض إلى الأرض.\",\"subtitle\":\"توجيه الأعمال في قطاع الأغذية بخبرة تجمع بين تطوير الأعمال والإبداع في علوم الغذاء.\"},\"story\":{\"eyebrow\":\"قصتنا\",\"heading\":\"بُنيت على أيدي خبراء عاشوا هذا العمل\",\"p1\":\"يتخصص همام في توجيه الأعمال في قطاع الأغذية — بدءًا من الإنتاج والطبخ إلى التصنيع والتدريب وخدمات الجودة وتخطيط الدعم اللوجستي.\",\"p2\":\"تقود هذه المؤسسة نخبة من الخبراء في الغذاء والجودة، تجمع بين خبرة تطوير الأعمال والإبداع في علوم الغذاء. نحن نفهم التحديات الحقيقية لإدارة عمليات الغذاء على نطاق واسع.\",\"p3\":\"من المطاعم ومطابخ الإعاشة إلى مصانع الأغذية وشركات الحج، نبني الأطر التي تحول الطموح إلى نجاح مستدام.\"},\"vision\":{\"eyebrow\":\"رؤيتنا\",\"title\":\"قيادة مستقبل الاستشارات الغذائية\",\"description\":\"أن نكون رواداً في الاستشارات وتطوير الأعمال في قطاع الأغذية، مع ضمان استدامة المنشآت الناجحة.\"},\"mission\":{\"eyebrow\":\"رسالتنا\",\"title\":\"نبني. ندرّب. نستدام.\",\"description\":\"بناء استراتيجيات وخطط عالية الجودة للمنشآت الغذائية وتدريب فرقها لتحقيق نجاح مستدام في الأعمال.\"},\"values\":{\"eyebrow\":\"ما نؤمن به\",\"title\":\"قيمنا ومبادئنا\",\"subtitle\":\"مستوحاة من رؤية المملكة العربية السعودية وهويتنا وغنى ثقافتنا، يحلق همام نحو آفاق جديدة في عالم الأعمال.\",\"list\":{\"trust\":{\"title\":\"الثقة\",\"description\":\"نبني علاقات دائمة قائمة على الشفافية والموثوقية. يثق بنا عملاؤنا لأننا نكسب هذه الثقة — في كل مشروع وكل تسليم.\"},\"partnership\":{\"title\":\"الشراكة\",\"description\":\"لا نقدم استشارات فحسب — بل نتعاون. كل مشروع هو شراكة حقيقية حيث يكون نجاحكم مقياس إنجازنا.\"},\"quality\":{\"title\":\"الجودة\",\"description\":\"نلتزم نحن وعملاؤنا بأعلى المعايير. كل توصية وكل نظام وكل برنامج تدريبي يعكس التزامنا بالتميز.\"},\"responsibility\":{\"title\":\"المسؤولية\",\"description\":\"نتحمل مسؤولية النتائج. من سلامة الغذاء إلى التخطيط التشغيلي، نضمن أن كل حل نقدمه يحقق تأثيراً قابلاً للقياس ودائماً.\"},\"excellence\":{\"title\":\"التميز\",\"description\":\"نسعى لأعلى المعايير في كل ما نقوم به — من دعم شهادات الآيزو إلى التدريب على الطهي — ولا نقبل بأقل من ذلك.\"}},\"taglineEyebrow\":\"ما نؤمن به\",\"tagline\":\"الثقة. الشراكة. الجودة. المسؤولية. التميز.\"},\"commitment\":{\"eyebrow\":\"وعدنا\",\"title\":\"أكثر من مستشارين — شركاء ملتزمون\",\"description\":\"في همام نحن أكثر من مستشارين — نحن شركاء ملتزمون بنجاح عملائنا في صناعة الأغذية. نؤمن بأن كل منشأة غذائية تستحق أنظمة وتدريبًا وإشرافًا عالمي المستوى.\"},\"leadership\":{\"eyebrow\":\"القيادة\",\"title\":\"الخبراء وراء همام\",\"subtitle\":\"عقود من الخبرة العملية في عمليات الغذاء وضمان الجودة والتميز في الطهي. عشنا هذا العمل. والآن نقوده.\",\"list\":{\"atef\":{\"name\":\"عاطف العريشي\",\"role\":\"المؤسس والمدير العام\",\"bio\":\"مع 27 عامًا من الخبرة في إدارة قطاع الإعاشة لحجاج بيت الله الحرام والمعتمرين، عاطف متخصص في تشغيل الوجبات مسبقة التحضير. لديه أيضًا أكثر من 7 سنوات من الخبرة في إدارة سلسلة التوريد والخدمات اللوجستية. بدأ مسيرته المهنية بإدارة تنسيق الفعاليات الخارجية الكبرى.\"},\"enas\":{\"name\":\"إيناس خضري\",\"role\":\"شيف استشاري ومديرة الطهي\",\"bio\":\"مع 16 عامًا من الخبرة في الطهي، تشتهر إيناس بإبداعها ومثابرتها وتفانيها. وهي عضو في عدة جمعيات سعودية ودولية للطهاة ومعتمدة من هيئة فنون الطهي كخبيرة في توثيق المطبخ السعودي. تمثل إيناس المملكة العربية السعودية في مجتمع الحلال العالمي.\"},\"alaa\":{\"name\":\"آلاء زهدي\",\"role\":\"مهندسة تصنيع أغذية وجودة\",\"bio\":\"تتخصص آلاء في عمليات تصنيع الأغذية وضمان الجودة والتطوير والاستشارات. شغوفة بتطوير صناعة الأغذية، تبحث بنشاط وتتبنى الابتكارات التكنولوجية لتقديم حلول تعزز كفاءة الإنتاج وتقلل الهدر.\"}}},\"quality\":{\"eyebrow\":\"الالتزام بالجودة\",\"title\":\"معايير معتمدة. نتائج مثبتة.\",\"description\":\"يتبنى همام نهجًا دقيقًا في تطبيق أعلى معايير الجودة، ويقدم دعمًا شاملاً للعملاء في إنشاء أنظمة جودة فعالة وضمان أداء استثنائي.\",\"stats\":{\"years\":\"+27\",\"yearsLabel\":\"سنة من الخبرة\",\"projects\":\"+200\",\"projectsLabel\":\"مشروع منجز\",\"certifications\":\"+50\",\"certificationsLabel\":\"شهادة محققة\",\"industries\":\"6\",\"industriesLabel\":\"قطاعات مخدومة\"}}},\"TrainingCenterPage\":{\"badge\":\"مركز التدريب\",\"title\":\"مركز همام للتدريب\",\"description\":\"قريباً\",\"ctaPrimary\":\"العودة للرئيسية\"},\"NotFound\":{\"badge\":\"خطأ 404\",\"title\":\"الصفحة غير موجودة\",\"description\":\"الصفحة التي تبحث عنها غير موجودة أو ربما تم نقلها.\",\"buttons\":{\"home\":\"العودة للرئيسية\",\"services\":\"استكشف خدماتنا\",\"contact\":\"تواصل معنا\"}}},\"timeZone\":\"Asia/Riyadh\",\"children\":[\"$L3\",\"$L4\",\"$L5\"]}]}]}]]}],\"loading\":null,\"isPartial\":false}\n3:[\"$\",\"$L6\",null,{}]\n4:[\"$\",\"$L7\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L8\",null,{}],\"notFound\":[[\"$\",\"$L9\",null,{}],[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/cc6a39f6c6655594.css\",\"precedence\":\"next\"}]]]}]\n5:[\"$\",\"footer\",null,{\"className\":\"Footer-module__yg9ahW__footer\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container Footer-module__yg9ahW__inner\",\"children\":[[\"$\",\"div\",null,{\"c