\":true}]],[\"$\",\"html\",null,{\"lang\":\"en\",\"dir\":\"ltr\",\"className\":\"inter_c15e96cb-module__0bjUvq__variable outfit_9f4f9187-module__4LtYgq__variable tajawal_7b9e7912-module__S44iHW__variable\",\"children\":[\"$\",\"body\",null,{\"children\":[\"$\",\"$L2\",null,{\"locale\":\"en\",\"messages\":{\"HomePage\":{\"badge\":\"Powered by Excellence\",\"title\":\"Elevate Food Quality\",\"subtitle\":\"Ensure Sustainable Success.\",\"description\":\"Expert consultancy, structural planning, and quality assurance for the modern catering and food industry.\",\"ctaPrimary\":\"Discuss Your Project\",\"ctaSecondary\":\"Explore Our Services\"},\"Navbar\":{\"home\":\"Home\",\"about\":\"About Us\",\"services\":\"Services\",\"industries\":\"Industries\",\"training\":\"Training Center\",\"contact\":\"Contact\",\"login\":\"Client Portal\"},\"About\":{\"eyebrow\":\"Our Story\",\"title\":\"A beacon in the sea of food.\",\"description\":\"Humam specializes in guiding businesses in the food sector, from production to manufacturing, training, quality services, and logistical support planning.\",\"cta\":\"Learn More About Humam\",\"pillars\":{\"dev\":\"Business Development\",\"safety\":\"Food Safety & Quality\",\"training\":\"Training & Human Capital\"}},\"Services\":{\"eyebrow\":\"Our Expertise\",\"title\":\"Comprehensive Solutions for the Food Industry\",\"dev\":{\"title\":\"Consultancy & Business Development\",\"desc\":\"Strategic planning, menu design, and operational excellence for food projects.\"},\"safety\":{\"title\":\"Quality & Food Safety\",\"desc\":\"ISO & HACCP certification preparation and rigorous safety audits.\"},\"training\":{\"title\":\"Training & Development\",\"desc\":\"Empowering chefs and employees with specialized culinary and safety programs.\"}},\"Industries\":{\"eyebrow\":\"Our Reach\",\"title\":\"Industries We Serve\",\"list\":{\"rest\":\"Restaurants & Catering\",\"bakery\":\"Bakeries & Pastry\",\"factory\":\"Food Factories\",\"hotel\":\"Hotels & Cafes\",\"hajj\":\"Hajj Companies\",\"healthy\":\"Healthy Meal Companies\"}},\"Challenges\":{\"eyebrow\":\"Challenges We Overcome\",\"title\":\"Why Choose Humam\",\"description\":\"We help you navigate the complexities of the food industry, turning obstacles into sustainable growth.\",\"list\":{\"quality\":{\"title\":\"Balance Quality & Cost\",\"desc\":\"Deliver high quality at reasonable prices without compromising standards.\"},\"efficiency\":{\"title\":\"Improve Operational Efficiency\",\"desc\":\"Streamline internal processes to reduce costs and boost productivity.\"},\"growth\":{\"title\":\"Launch New Projects\",\"desc\":\"Navigate growth and expansion from initial idea to seamless execution.\"},\"sustainability\":{\"title\":\"Achieve Sustainability\",\"desc\":\"Balance profitability with social and environmental responsibility.\"},\"reputation\":{\"title\":\"Build Strong Reputation\",\"desc\":\"Establish a trustworthy brand that attracts clients and partners.\"}}},\"Experts\":{\"eyebrow\":\"Our Leadership\",\"title\":\"Meet the Experts\",\"list\":{\"atef\":{\"name\":\"Atef Al-Arishi\",\"role\":\"General Manager\",\"bio\":\"27 years managing catering for Hajj & Umrah, with expertise in supply chain and pre-prepared meals.\"},\"enas\":{\"name\":\"Enas Khodary\",\"role\":\"Consultant Chef\",\"bio\":\"16 years culinary experience, certified by Culinary Arts Authority as an expert in Saudi cuisine.\"},\"alaa\":{\"name\":\"Alaa Zahdi\",\"role\":\"Food Manufacturing Engineer\",\"bio\":\"Specializes in food manufacturing, quality assurance, and adopting technological innovations.\"}}},\"FinalCTA\":{\"title\":\"Ready to Elevate Your Food Business?\",\"cta\":\"Start Your Journey\"},\"ServicesPage\":{\"hero\":{\"eyebrow\":\"Our Services\",\"title\":\"Precision-Built Solutions for the Food Industry\",\"subtitle\":\"From strategy to certification, from training to transformation — we deliver end-to-end expertise that elevates every layer of your food operation.\"},\"philosophy\":{\"eyebrow\":\"Our Approach\",\"heading\":\"Systems That Scale. Standards That Last.\",\"p1\":\"Every engagement begins with deep understanding. We study your operations, your market, and your goals before recommending a single change.\",\"p2\":\"Our methodology integrates consultancy, quality systems, and human development into a unified framework — because sustainable success requires all three.\",\"p3\":\"We don't deliver templates. We build systems tailored to your context, your culture, and your growth trajectory.\"},\"consultancy\":{\"number\":\"01\",\"eyebrow\":\"Consultancy & Business Development\",\"title\":\"Build the Foundation. Design the Future.\",\"description\":\"Strategic planning, operational architecture, and menu engineering for food businesses that demand excellence.\",\"body\":\"We work alongside founders, operators, and leadership teams to design every layer of your food business — from initial concept through to sustainable scale. Our consultancy isn't theoretical. It's built on decades of hands-on food industry experience.\",\"cta\":\"Explore Consultancy\",\"benefits\":\"Office & field consultations, Menu design & engineering, Project establishment & planning, Operational systems & SOPs, Cost & calorie calculations, Sustainability transformation\",\"items\":{\"office\":{\"title\":\"Office & Field Consultations\",\"desc\":\"On-site and remote expert assessments to diagnose and elevate your operations.\"},\"menu\":{\"title\":\"Menu Design & Engineering\",\"desc\":\"Data-driven menu development that balances creativity, cost, and customer demand.\"},\"project\":{\"title\":\"Project Establishment & Planning\",\"desc\":\"End-to-end setup for new food ventures — from concept to operational launch.\"}}},\"quality\":{\"number\":\"02\",\"eyebrow\":\"Quality & Food Safety\",\"title\":\"Certify. Protect. Excel.\",\"description\":\"International quality systems, food safety protocols, and compliance frameworks that protect your brand and your customers.\",\"body\":\"From ISO certification to HACCP implementation, we build the quality infrastructure that regulators trust and customers rely on. Every system we design is audit-ready from day one — with full documentation, staff training, and continuous improvement frameworks.\",\"cta\":\"Explore Quality Systems\",\"benefits\":\"ISO 9001 & ISO 22000 certification, HACCP system implementation, Good Manufacturing Practices (GMP), Internal audit frameworks, Compliance documentation, Corrective action protocols\",\"items\":{\"iso\":{\"title\":\"ISO Certification Systems\",\"desc\":\"ISO 9001 and ISO 22000 implementation with full documentation and audit readiness.\"},\"haccp\":{\"title\":\"HACCP & GMP\",\"desc\":\"Hazard analysis, critical control points, and good manufacturing practices for every production line.\"},\"audit\":{\"title\":\"Audits & Compliance\",\"desc\":\"Comprehensive safety audits with actionable corrective measures and ongoing monitoring.\"}}},\"training\":{\"number\":\"03\",\"eyebrow\":\"Training & Development\",\"title\":\"Invest in People. Multiply Results.\",\"description\":\"Specialized culinary and operational training programs that transform teams into high-performing assets.\",\"body\":\"Our training programs are designed by practitioners who have led kitchens, managed operations, and built teams from the ground up. Every session combines hands-on practice with real-world application — because lasting change happens through doing.\",\"cta\":\"Explore Training Programs\",\"benefits\":\"Employee training programs, Chef development & technique, Specialized workshops, Food safety certification prep, Kitchen leadership coaching, Custom program design\",\"items\":{\"employee\":{\"title\":\"Employee Training\",\"desc\":\"Foundational and advanced programs for kitchen staff, service teams, and operations managers.\"},\"chef\":{\"title\":\"Chef Development\",\"desc\":\"Advanced culinary technique, menu innovation, and leadership development for professional chefs.\"},\"specialized\":{\"title\":\"Workshops & Specialized Programs\",\"desc\":\"Targeted sessions on food safety, sustainability, and industry-specific best practices.\"}}}},\"ConsultancyPage\":{\"hero\":{\"eyebrow\":\"Consultancy & Business Development\",\"title\":\"Strategic Architecture for Food Excellence\",\"subtitle\":\"From initial concept to operational mastery — we design the frameworks that turn ambition into sustainable, scalable food businesses.\"},\"intro\":{\"eyebrow\":\"What We Deliver\",\"heading\":\"Every Detail. Engineered for Growth.\",\"description\":\"Our consultancy covers the full spectrum of food business development — whether you're launching a new concept, optimizing an existing operation, or scaling across multiple locations.\"},\"offerings\":{\"office\":{\"title\":\"Office Consultations\",\"desc\":\"In-depth strategic sessions at our offices to analyze your business model, identify gaps, and map your growth trajectory.\",\"included\":\"Business model analysis, gap assessment, strategic roadmap, performance benchmarking\"},\"field\":{\"title\":\"Field Consultations\",\"desc\":\"On-site expert assessments of your facilities, workflows, and team performance with actionable improvement plans.\",\"included\":\"Facility audit, workflow analysis, staff evaluation, corrective action plan\"},\"menu\":{\"title\":\"Menu Design\",\"desc\":\"Data-driven menu engineering that balances culinary creativity with cost optimization and market positioning.\",\"included\":\"Menu architecture, pricing strategy, ingredient sourcing, seasonal planning\"},\"project\":{\"title\":\"Project Establishment\",\"desc\":\"Complete setup guidance for new food ventures — from concept development through to operational launch.\",\"included\":\"Concept design, feasibility study, licensing guidance, launch planning\"},\"operational\":{\"title\":\"Operational Planning\",\"desc\":\"Systematic optimization of daily operations to maximize efficiency, reduce waste, and improve consistency.\",\"included\":\"SOP development, workflow design, capacity planning, KPI frameworks\"},\"sustainability\":{\"title\":\"Sustainability Transformation\",\"desc\":\"Transition your operations toward sustainable practices without compromising quality or profitability.\",\"included\":\"Waste reduction, energy optimization, sustainable sourcing, reporting frameworks\"},\"cost\":{\"title\":\"Cost Calculations\",\"desc\":\"Precise cost analysis and modeling to protect margins, optimize purchasing, and ensure financial sustainability.\",\"included\":\"Food cost analysis, labor cost modeling, overhead allocation, pricing optimization\"},\"calorie\":{\"title\":\"Calorie Calculations\",\"desc\":\"Accurate nutritional analysis and calorie calculations for menu compliance and health-conscious positioning.\",\"included\":\"Nutritional analysis, allergen mapping, labeling compliance, health menu development\"}}},\"QualityPage\":{\"hero\":{\"eyebrow\":\"Quality & Food Safety\",\"title\":\"International Standards. Uncompromising Execution.\",\"subtitle\":\"We build quality management systems that protect your brand, satisfy regulators, and give your customers absolute confidence.\"},\"intro\":{\"eyebrow\":\"Our Quality Framework\",\"heading\":\"Systems Built to Certify. Designed to Last.\",\"description\":\"From ISO certification to HACCP implementation, we provide end-to-end quality system design, documentation, training, and audit preparation.\"},\"standards\":{\"iso9001\":{\"title\":\"ISO 9001\",\"subtitle\":\"Quality Management System\",\"goal\":\"Establish a comprehensive quality management system that ensures consistent product quality and continuous improvement.\",\"included\":\"Quality policy development, process documentation, internal audit framework, management review system, corrective action procedures\",\"steps\":\"Gap analysis, System design, Documentation, Staff training, Internal audit, Certification audit\"},\"iso22000\":{\"title\":\"ISO 22000\",\"subtitle\":\"Food Safety Management System\",\"goal\":\"Implement an internationally recognized food safety management system covering the entire food chain.\",\"included\":\"Hazard analysis, prerequisite programs, FSMS documentation, traceability systems, emergency preparedness\",\"steps\":\"Current state assessment, Hazard identification, Control measures, System documentation, Verification, Certification\"},\"haccp\":{\"title\":\"HACCP\",\"subtitle\":\"Hazard Analysis & Critical Control Points\",\"goal\":\"Identify, evaluate, and control hazards that are significant to food safety at every stage of production.\",\"included\":\"Hazard analysis, CCP identification, critical limits, monitoring procedures, corrective actions, verification protocols\",\"steps\":\"Team assembly, Product description, Flow diagram, Hazard analysis, CCP determination, System validation\"},\"gmp\":{\"title\":\"GMP\",\"subtitle\":\"Good Manufacturing Practices\",\"goal\":\"Ensure that food products are consistently produced and controlled according to quality standards appropriate for their intended use.\",\"included\":\"Facility design review, hygiene protocols, pest control programs, equipment maintenance, personnel practices\",\"steps\":\"Facility assessment, Protocol development, Staff training, Implementation, Monitoring, Continuous improvement\"}}},\"TrainingPage\":{\"hero\":{\"eyebrow\":\"Training & Development\",\"title\":\"Transform Teams. Elevate Performance.\",\"subtitle\":\"Specialized programs that build capability, instill excellence, and create lasting operational impact across every level of your organization.\"},\"intro\":{\"eyebrow\":\"Training Philosophy\",\"heading\":\"Knowledge That Transfers. Skills That Stay.\",\"description\":\"Our training programs are designed by practitioners, not theorists. Every session combines hands-on practice with real-world application — because lasting change happens through doing, not just learning.\"},\"programs\":{\"employee\":{\"title\":\"Employee Training\",\"desc\":\"Comprehensive foundational programs for kitchen staff, service teams, and operations managers. We build the baseline competency that excellent operations require.\",\"outcomes\":\"Improved food handling, standardized procedures, reduced waste, higher team confidence\"},\"chef\":{\"title\":\"Chef Development\",\"desc\":\"Advanced culinary programs focused on technique refinement, menu innovation, kitchen leadership, and creative development for professional chefs.\",\"outcomes\":\"Enhanced technique, menu innovation capability, leadership skills, creative confidence\"},\"workshops\":{\"title\":\"Workshops\",\"desc\":\"Intensive, focused workshops on specific topics — from food safety compliance to sustainability practices and industry trend analysis.\",\"outcomes\":\"Targeted skill acquisition, certification readiness, practical implementation plans\"},\"specialized\":{\"title\":\"Specialized Programs\",\"desc\":\"Custom-designed training programs tailored to your specific operational challenges, team composition, and business objectives.\",\"outcomes\":\"Custom skill development, operational alignment, measurable performance improvement\"}},\"cta\":{\"eyebrow\":\"Ready to Invest in Your Team?\",\"title\":\"Request a Training Program\",\"description\":\"Tell us about your team and your goals. We'll design a program that delivers measurable results.\",\"button\":\"Request Training\"}},\"ContactPage\":{\"title\":\"Schedule a Consultation\",\"description\":\"Bring your challenges, your goals, or your existing operations. We'll assess them with you live — and show you exactly how Humam can help.\",\"bullets\":{\"b1\":\"Your operation. Expert insight.\",\"b2\":\"Real gaps identified, real solutions proposed\",\"b3\":\"See what structured excellence looks like\"},\"testimonial\":{\"quote\":\"Humam didn't just consult — they transformed how we think about quality and operations. The results speak for themselves.\",\"role\":\"Operations Director\",\"company\":\"Leading Catering Company\"},\"info\":{\"emailLabel\":\"Email Us\",\"email\":\"info@humam.sa\",\"locationLabel\":\"Location\",\"location\":\"Makkah, Saudi Arabia\"},\"form\":{\"heading\":\"Talk to Humam\",\"name\":\"Name\",\"namePlaceholder\":\"Your name\",\"email\":\"Email\",\"emailPlaceholder\":\"Work email\",\"company\":\"Company (Optional)\",\"companyPlaceholder\":\"Company\",\"message\":\"Message\",\"messagePlaceholder\":\"Tell us about your operation\",\"industry\":\"Industry\",\"industryOptions\":{\"select\":\"Select\",\"restaurants\":\"Restaurants & Catering\",\"bakeries\":\"Bakeries & Pastry\",\"factories\":\"Food Factories\",\"hotels\":\"Hotels & Cafes\",\"hajj\":\"Hajj Companies\",\"healthy\":\"Healthy Meal Companies\"},\"service\":\"Service Interest\",\"serviceOptions\":{\"select\":\"Select\",\"consultancy\":\"Consultancy & Business Development\",\"quality\":\"Quality & Food Safety\",\"training\":\"Training & Development\"},\"submit\":\"Request Consultation\",\"submitting\":\"Please wait...\",\"successTitle\":\"Thank you for your interest!\",\"successMessage\":\"We'll respond within 24 hours.\",\"errorMessage\":\"Oops! Something went wrong while submitting the form.\",\"required\":\"This field is required\",\"invalidEmail\":\"Please enter a valid email address\",\"responseTime\":\"We respond within 24 hours\",\"secure\":\"Your information is kept confidential\"}},\"AboutPage\":{\"hero\":{\"eyebrow\":\"About Humam\",\"title\":\"A beacon in the sea of food, from the ground to the ground.\",\"subtitle\":\"Guiding businesses in the food sector with expertise that combines business development with creativity in food sciences.\"},\"story\":{\"eyebrow\":\"Our Story\",\"heading\":\"Built by Experts Who Lived This Work\",\"p1\":\"Humam specializes in guiding businesses in the food sector — from production and cooking to manufacturing, training, quality services, and logistical support planning.\",\"p2\":\"This institution is led by experts in food and quality, combining business development expertise with creativity in food sciences. We understand the real challenges of running food operations at scale.\",\"p3\":\"From restaurants and catering kitchens to food factories and Hajj companies, we build the frameworks that turn ambition into sustainable success.\"},\"vision\":{\"eyebrow\":\"Our Vision\",\"title\":\"Leading the Future of Food Consultancy\",\"description\":\"To become leaders in consultancy and business development in the food sector, ensuring the sustainability of successful enterprises.\"},\"mission\":{\"eyebrow\":\"Our Mission\",\"title\":\"Build. Train. Sustain.\",\"description\":\"To build high-quality strategies and plans for food organizations and train their teams to achieve sustainable business success.\"},\"values\":{\"eyebrow\":\"What We Stand For\",\"title\":\"Our Values & Principles\",\"subtitle\":\"Inspired by the vision of the Kingdom of Saudi Arabia, our identity, and the richness of our culture, Humam soars to new heights in business.\",\"list\":{\"trust\":{\"title\":\"Trust\",\"description\":\"We build lasting relationships founded on transparency and reliability. Our clients trust us because we earn it — every engagement, every deliverable.\"},\"partnership\":{\"title\":\"Partnership\",\"description\":\"We don't just consult — we collaborate. Every engagement is a true partnership where your success is our measure of achievement.\"},\"quality\":{\"title\":\"Quality\",\"description\":\"We hold ourselves and our clients to the highest standards. Every recommendation, every system, every training program reflects our commitment to excellence.\"},\"responsibility\":{\"title\":\"Responsibility\",\"description\":\"We take ownership of outcomes. From food safety to operational planning, we ensure that every solution we deliver creates measurable, lasting impact.\"},\"excellence\":{\"title\":\"Excellence\",\"description\":\"We pursue the highest standard in everything we do — from ISO certification support to culinary training — never settling for less.\"}},\"taglineEyebrow\":\"What we value\",\"tagline\":\"Trust. Partnership. Quality. Responsibility. Excellence.\"},\"commitment\":{\"eyebrow\":\"Our Promise\",\"title\":\"More Than Consultants — Committed Partners\",\"description\":\"At Humam we are more than consultants — we are committed partners dedicated to the success of our clients in the food industry. We believe every food business deserves world-class systems, training, and oversight.\"},\"leadership\":{\"eyebrow\":\"Leadership\",\"title\":\"The Experts Behind Humam\",\"subtitle\":\"Decades of hands-on experience in food operations, quality assurance, and culinary excellence. We lived this work. Now we lead it.\",\"list\":{\"atef\":{\"name\":\"Atef Al-Arishi\",\"role\":\"Founder & General Manager\",\"bio\":\"With 27 years of experience managing the catering sector for Hajj and Umrah pilgrims, Atef is a specialist in operating pre-prepared meals. He also has over 7 years of expertise in supply chain management and logistics. His career began with managing high-profile external event coordination.\"},\"enas\":{\"name\":\"Enas Khodary\",\"role\":\"Consultant Chef & Culinary Director\",\"bio\":\"With 16 years of culinary experience, Enas is renowned for her creativity, persistence, and dedication. She is a member of multiple Saudi and international chef associations and is certified by the Culinary Arts Authority as an expert in documenting Saudi cuisine. Enas represents Saudi Arabia in the global Halal community.\"},\"alaa\":{\"name\":\"Alaa Zahdi\",\"role\":\"Food Manufacturing & Quality Engineer\",\"bio\":\"Alaa specializes in food manufacturing processes, quality assurance, development, and consulting. Passionate about advancing the food industry, she actively researches and adopts technological innovations to provide solutions that enhance production efficiency and minimize waste.\"}}},\"quality\":{\"eyebrow\":\"Quality Commitment\",\"title\":\"Certified Standards. Proven Results.\",\"description\":\"Humam adopts a meticulous approach to implementing the highest quality standards, providing comprehensive support to clients in establishing effective quality systems and ensuring exceptional performance.\",\"stats\":{\"years\":\"27+\",\"yearsLabel\":\"Years of Experience\",\"projects\":\"200+\",\"projectsLabel\":\"Projects Delivered\",\"certifications\":\"50+\",\"certificationsLabel\":\"Certifications Achieved\",\"industries\":\"6\",\"industriesLabel\":\"Industries Served\"}}},\"TrainingCenterPage\":{\"badge\":\"Training Center\",\"title\":\"Humam Training Center\",\"description\":\"Coming Soon\",\"ctaPrimary\":\"Back to Home\"},\"NotFound\":{\"badge\":\"Error 404\",\"title\":\"Page Not Found\",\"description\":\"The page you are looking for doesn't exist or may have been moved.\",\"buttons\":{\"home\":\"Return to Homepage\",\"services\":\"Explore Services\",\"contact\":\"Contact Us\"}}},\"timeZone\":\"Asia/Riyadh\",\"children\":[\"$L3\",\"$L4\",\"$L5\"]}]}]}]]}],\"loading\":null,\"isPartial\":false}\n3:[\"$\",\"$L6\",null,{}]\n4:[\"$\",\"$L7\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L8\",null,{}],\"notFound\":[[\"$\",\"$L9\",null,{}],[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/cc6a39f6c6655594.css\",\"precedence\":\"next\"}]]]}]\n5:[\"$\",\"footer\",null,{\"className\":\"Footer-module__yg9ahW__footer\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container Footer-module__yg9ahW__inner\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Footer-module__yg9ahW__leftColumn\",\"children\":[[\"$\",\"div\",null,{\"className\":\"Footer-module__yg9ahW__brand\",\"children\":[[\"$\",\"$La\",null,{\"href\":\"/en\",\"localeCookie\":{\"name\":\"NEXT_LOCALE\",\"sameSite\":\"lax\"},\"children\":[\"$\",\"$Lb\",null,{\"src\":\"/images/brand/Humam-Logo.svg\",\"alt\":\"Logo\",\"width\":100,\"height\":100}]}],[\"$\",\"p\",null,{\"children\":\"Expert co