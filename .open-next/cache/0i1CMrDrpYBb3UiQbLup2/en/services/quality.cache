od Safety,Quality Assurance,Facility Design,Corporate Training,ISO Certifications,Saudi Arabia Consulting\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"Humam Consulting | Expert Quality Assurance\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:description\",\"content\":\"Premium expertise in food safety, quality assurance, facility design, and specialized training.\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:url\",\"content\":\"https://humamconsulting.com\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:site_name\",\"content\":\"Humam Consulting\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"9\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"10\",{\"name\":\"twitter:title\",\"content\":\"Humam Consulting\"}],[\"$\",\"meta\",\"11\",{\"name\":\"twitter:description\",\"content\":\"Expert consultancy and quality assurance for the food industry.\"}],[\"$\",\"link\",\"12\",{\"rel\":\"shortcut icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"link\",\"13\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.0b3bf435.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"14\",{\"rel\":\"icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"link\",\"15\",{\"rel\":\"apple-touch-icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"$L5\",\"16\",{}]]}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}],\"loading\":null,\"isPartial\":false}\n"}}