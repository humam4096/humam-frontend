\"}]\n2a:I[27201,[\"/_next/static/chunks/ff1a16fafef87110.js\",\"/_next/static/chunks/d2be314c3ece3fbe.js\"],\"IconMark\"]\n9:null\nd:[[\"$\",\"title\",\"0\",{\"children\":\"Quality & Food Safety | Humam Consulting\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"ISO 9001, ISO 22000, HACCP, and GMP certification systems for the food industry.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Humam Consulting,Food Safety,Quality Assurance,Facility Design,Corporate Training,ISO Certifications,Saudi Arabia Consulting\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"Humam Consulting | Expert Quality Assurance\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:description\",\"content\":\"Premium expertise in food safety, quality assurance, facility design, and specialized training.\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:url\",\"content\":\"https://humamconsulting.com\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:site_name\",\"content\":\"Humam Consulting\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"9\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"10\",{\"name\":\"twitter:title\",\"content\":\"Humam Consulting\"}],[\"$\",\"meta\",\"11\",{\"name\":\"twitter:description\",\"content\":\"Expert consultancy and quality assurance for the food industry.\"}],[\"$\",\"link\",\"12\",{\"rel\":\"shortcut icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"link\",\"13\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.0b3bf435.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"14\",{\"rel\":\"icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"link\",\"15\",{\"rel\":\"apple-touch-icon\",\"href\":\"/images/brand/Humam-Logo-Short.svg\"}],[\"$\",\"$L2a\",\"16\",{}]]\n","/$d$locale/services/quality/__PAGE__":"1:\"$Sreact.fragment\"